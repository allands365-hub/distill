{
  "name": "triage",
  "description": "Classifies a piece of raw user feedback as bug/feature/question/duplicate/spam with a confidence score.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD"],
  "visibility": "POD",
  "agent_runtime": { "profile_id": "019f0ccf-773d-74e1-9ae6-1116c57d1134" },
  "input_schema": {
    "type": "object",
    "properties": {
      "title": { "type": "string" },
      "body": { "type": "string" }
    },
    "required": ["body"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "type": { "type": "string", "enum": ["bug", "feature", "question", "duplicate", "spam"] },
      "confidence": { "type": "number" },
      "reasoning": { "type": "string" }
    },
    "required": ["type", "confidence", "reasoning"]
  },
  "permissions": { "grants": [
    { "resource_type": "folder", "resource_name": "/knowledge",
      "permission_ids": ["folder.read"] }
  ] }
}
