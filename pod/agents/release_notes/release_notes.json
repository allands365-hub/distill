{
  "name": "release_notes",
  "description": "Writes friendly markdown release notes from a list of fixed issues.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": [],
  "visibility": "POD",
  "agent_runtime": { "profile_id": "019f0ccf-773d-74e1-9ae6-1116c57d1134" },
  "input_schema": {
    "type": "object",
    "properties": {
      "issues": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "type": { "type": "string" },
            "priority": { "type": "string" },
            "reasoning": { "type": "string" }
          }
        }
      }
    },
    "required": ["issues"]
  },
  "output_schema": {
    "type": "object",
    "properties": { "notes_md": { "type": "string" } },
    "required": ["notes_md"]
  },
  "permissions": { "grants": [] }
}
