{
  "name": "triage_batch",
  "description": "Triage a pasted batch of feedback: split into items, then per item classify, prioritize, dedup, generate repro steps for bugs, and save to the issues table with a computed status.",
  "start": { "type": "MANUAL" },
  "visibility": "POD",
  "nodes": [
    { "id": "intake", "type": "FORM", "label": "Paste feedback batch",
      "config": { "input_schema": { "type": "object",
        "properties": { "raw_text": { "type": "string" } }, "required": ["raw_text"] } } },
    { "id": "split", "type": "FUNCTION", "label": "Split batch",
      "config": { "function_name": "split_batch",
        "input_mapping": { "raw_text": { "type": "expression", "value": "intake.raw_text" } } } },
    { "id": "items_loop", "type": "LOOP", "label": "Each item",
      "config": { "items_path": "split.items", "item_var_name": "item", "child_node_id": "classify" } },
    { "id": "classify", "type": "AGENT", "label": "Classify",
      "config": { "agent_name": "triage",
        "input_mapping": { "title": { "type": "expression", "value": "loop.item.title" },
          "body": { "type": "expression", "value": "loop.item.body" } } } },
    { "id": "prio", "type": "FUNCTION", "label": "Priority",
      "config": { "function_name": "detect_priority",
        "input_mapping": { "item_type": { "type": "expression", "value": "classify.type" },
          "title": { "type": "expression", "value": "loop.item.title" },
          "body": { "type": "expression", "value": "loop.item.body" } } } },
    { "id": "dup", "type": "FUNCTION", "label": "Duplicates",
      "config": { "function_name": "detect_duplicates",
        "input_mapping": { "title": { "type": "expression", "value": "loop.item.title" },
          "body": { "type": "expression", "value": "loop.item.body" },
          "threshold": { "type": "literal", "value": 0.5 } } } },
    { "id": "is_bug", "type": "DECISION", "label": "Is bug?",
      "config": { "rules": [ { "condition": "classify.type == 'bug'", "next_node_id": "repro" } ] } },
    { "id": "repro", "type": "AGENT", "label": "Reproduction",
      "config": { "agent_name": "reproduction",
        "input_mapping": { "title": { "type": "expression", "value": "loop.item.title" },
          "body": { "type": "expression", "value": "loop.item.body" } } } },
    { "id": "save", "type": "FUNCTION", "label": "Save issue",
      "config": { "function_name": "save_issue",
        "input_mapping": {
          "source_text": { "type": "expression", "value": "loop.item.body" },
          "source_channel": { "type": "expression", "value": "loop.item.channel" },
          "title": { "type": "expression", "value": "loop.item.title" },
          "item_type": { "type": "expression", "value": "classify.type" },
          "confidence": { "type": "expression", "value": "classify.confidence" },
          "priority": { "type": "expression", "value": "prio.priority", "optional": true },
          "reasoning": { "type": "expression", "value": "classify.reasoning" },
          "repro_steps": { "type": "expression", "value": "repro.repro_steps", "optional": true },
          "linked_to": { "type": "expression", "value": "dup.linked_to", "optional": true },
          "status": { "type": "literal", "value": "auto" } } } },
    { "id": "end", "type": "END", "label": "Done" }
  ],
  "edges": [
    { "id": "e1", "source": "intake", "target": "split" },
    { "id": "e2", "source": "split", "target": "items_loop" },
    { "id": "e3", "source": "items_loop", "target": "end" },
    { "id": "e4", "source": "classify", "target": "prio" },
    { "id": "e5", "source": "prio", "target": "dup" },
    { "id": "e6", "source": "dup", "target": "is_bug" },
    { "id": "e7", "source": "is_bug", "target": "save" },
    { "id": "e8", "source": "is_bug", "target": "repro" },
    { "id": "e9", "source": "repro", "target": "save" },
    { "id": "e10", "source": "save", "target": "items_loop" }
  ]
}
